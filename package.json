  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.6.2",
    "dompurify": "^3.4.2",
    "electron-updater": "^6.8.3",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
